# Database
DATABASE_URL=postgresql://hacksuite:hacksuite@localhost:5432/hacksuite

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate: openssl genrsa 2048 | base64 -w 0
JWT_PRIVATE_KEY=your_rs256_private_key_base64
JWT_PUBLIC_KEY=your_rs256_public_key_base64

# Resend (https://resend.com)
RESEND_API_KEY=re_your_key_here

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
NODE_ENV=development

# Cookies
COOKIE_SECRET=change_this_to_32_random_chars_minimum
